async function civDone(id){const ok=await cfShow('✅','¿Completar?','Confirma que terminaste');if(!ok)return;try{await SB.from('pv_casos').update({estado:'completado'}).eq('id',id);toast('✅ Completado');await load()}catch(e){toast('Falta fotos/checklist','twarn')}}

/* ═══ CLIENT ═══ */
function rClient(){const el=$('sec-mi_inm');if(!el)return;const mI=findMyInq();if(!mI){el.innerHTML='<div class="emp"><span class="emp-i">🏠</span><h3>Inmueble no vinculado</h3><p>Contacta a la inmobiliaria</p></div>';return}
const p=mI.propiedad,mc=CASOS.filter(c=>c.inquilino_id===mI.id&&!['cerrado','rechazado','cancelado'].includes(c.estado)),cerr=CASOS.filter(c=>c.inquilino_id===mI.id&&c.estado==='cerrado');
let h=`<div style="padding:14px;background:linear-gradient(135deg,var(--b700),var(--b600));border-radius:var(--r);margin-bottom:12px;color:#fff"><div style="font-family:Fraunces,serif;font-size:18px;font-weight:800">Hola, ${mI.nombre} 👋</div><div style="font-size:11px;opacity:.7;margin-top:2px">📍 ${p?p.direccion+', '+p.ciudad:''}</div></div>`;
// Report button
h+=`<button class="report-btn" onclick="cReport('${mI.id}','${mI.propiedad_id}')"><span class="report-btn-ico">🚨</span><div><div class="report-btn-txt">Reportar un problema</div><div class="report-btn-sub">Reporta un daño o emergencia en tu inmueble</div></div></button>`;
// Active cases (expandable)
if(mc.length){h+=`<div style="font-family:Fraunces,serif;font-size:15px;font-weight:700;margin-bottom:8px">Casos activos (${mc.length})</div>`;mc.forEach((c,idx)=>{const ex=EX[c.estado]||{};h+=buildExpCard(c,idx===0)})}
// Closed
if(cerr.length){h+=`<div style="font-family:Fraunces,serif;font-size:15px;font-weight:700;margin:12px 0 8px">Resueltos</div>`;cerr.forEach(c=>{const eg=c.garantia_hasta&&new Date(c.garantia_hasta)>new Date();h+=`<div class="cli"><div class="cli-ico">✅</div><div class="cli-info"><div class="cli-t">${tk(c.numero_caso)} · ${c.problema?.nombre||''}</div></div>${eg?'<div class="cli-r"><span style="padding:2px 6px;border-radius:6px;font-size:8px;font-weight:700;background:var(--greenbg);color:#065f46">🛡️ Garantía</span></div>':''}</div>`})}
el.innerHTML=h}

function buildExpCard(c,open){
  const ex=EX[c.estado]||{};
  const steps=['reportado','validado','asignado','en_camino','en_ejecucion','completado','cerrado'];
  const ci=steps.indexOf(c.estado);
  let timeline='<div class="prg">';
  steps.forEach((s,i)=>{const e=EX[s]||{};const cls=i<ci?'done':i===ci?'active':'future';let ts='';if(i<=ci){const t=c[s+'_at']||c.created_at;if(t)ts=new Date(t).toLocaleString('es-CO',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}
  // Reassignment marker
  let reas='';if(s==='asignado'&&c.reasignaciones>0)reas=`<div style="margin:4px 0;padding:6px 8px;background:var(--goldbg);border:1px solid var(--yb);border-radius:6px;font-size:10px;color:#92400e">⚠️ Profesional reasignado${c.motivo_reasignacion?' — '+c.motivo_reasignacion:''}</div>`;
  timeline+=`<div class="prg-s ${cls}"><div class="prg-d">${e.i||'○'}</div><div class="prg-i"><div class="prg-t">${e.t||s}</div>${i<=ci?`<div class="prg-desc">${e.d||''}</div>`:''}<div class="prg-tm">${ts}</div>${reas}</div></div>`});
  timeline+='</div>';
  // Professional card
  let profCard='';if(c.profesional)profCard=`<div style="margin-top:8px;padding:8px;background:var(--greenbg);border:1px solid var(--gb);border-radius:8px;font-size:11px">🔧 <b>${c.profesional.nombre}</b> · ⭐ ${c.profesional.rating_promedio}</div>`;
  // Rating
  let rating='';if(c.estado==='completado'&&!c.calificacion_inquilino)rating=`<div style="text-align:center;padding:12px;background:var(--goldbg);border:1.5px solid var(--yb);border-radius:8px;margin-top:8px"><div style="font-size:13px;font-weight:800;margin-bottom:6px">⭐ Califica el servicio</div><div style="display:flex;justify-content:center;gap:10px">${[1,2,3,4,5].map(n=>`<button style="font-size:28px;background:none;border:none;cursor:pointer" onclick="cRate('${c.id}',${n})">⭐</button>`).join('')}</div></div>`;
  if(c.calificacion_inquilino)rating=`<div style="text-align:center;font-size:12px;color:var(--green);font-weight:700;margin-top:6px">${'⭐'.repeat(c.calificacion_inquilino)}</div>`;
  if(c.garantia_hasta)rating+=`<div style="padding:8px;background:var(--greenbg);border:1px solid var(--gb);border-radius:6px;font-size:10px;color:#065f46;text-align:center;margin-top:6px">🛡️ Garantía hasta ${new Date(c.garantia_hasta).toLocaleDateString('es-CO')}</div>`;

  return`<div class="exp-card" id="ec_${c.id}"><div class="exp-hdr" onclick="togExp('${c.id}')"><span style="font-size:22px">${ex.i||'📩'}</span><div style="flex:1"><div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap"><span class="ticket-num">${tk(c.numero_caso)}</span>${uB(c.urgencia)}</div><div style="font-size:13px;font-weight:700;margin-top:3px">${ex.t||c.estado}</div><div style="font-size:10px;color:var(--sub)">${c.categoria?.icono||''} ${c.problema?.nombre||''}</div></div><span class="exp-arr ${open?'open':''}">›</span></div><div class="exp-body ${open?'show':''}">${timeline}${profCard}${rating}</div></div>`}

function togExp(id){const b=document.querySelector('#ec_'+id+' .exp-body'),a=document.querySelector('#ec_'+id+' .exp-arr');if(b)b.classList.toggle('show');if(a)a.classList.toggle('open')}

function rClientRep(){const el=$('sec-mis_rep');if(!el)return;const mI=findMyInq();if(!mI){el.innerHTML='<div class="emp"><span class="emp-i">📋</span><h3>Sin reportes</h3></div>';return}const todos=CASOS.filter(c=>c.inquilino_id===mI.id);
let h=`<div style="font-family:Fraunces,serif;font-size:16px;font-weight:700;margin-bottom:10px">Mis reportes (${todos.length})</div>`;
if(!todos.length){el.innerHTML=h+'<div class="emp"><span class="emp-i">📋</span><h3>Sin reportes</h3><p>Usa el botón de reporte en tu pantalla principal</p></div>';return}
todos.forEach((c,i)=>{h+=buildExpCard(c,i===0)});el.innerHTML=h}

async function cRate(id,n){await SB.from('pv_casos').update({calificacion_inquilino:n}).eq('id',id);toast('⭐ Gracias');await load()}

/* CLIENT REPORT */
function cReport(iId,pId){$('mtt').textContent='Reportar problema';$('msb3').textContent='Cuéntanos qué pasó';
let b=`<div class="ff"><label class="ffl">¿Qué se dañó? <span class="ffr">*</span></label><select class="ffi" id="cr_c" onchange="crCC2()"><option value="">Seleccionar...</option>${CATS.map(c=>`<option value="${c.id}">${c.icono} ${c.nombre}</option>`).join('')}</select></div>`;
b+=`<div class="ff"><label class="ffl">Problema específico <span class="ffr">*</span></label><select class="ffi" id="cr_p" onchange="crProbChanged()"><option value="">Primero selecciona qué se dañó</option></select></div>`;
b+=`<div id="cr_alert" style="display:none"></div>`;
b+=`<div class="ff"><label class="ffl">Describe el problema <span class="ffr">*</span></label><textarea class="ffi" id="cr_d" style="min-height:70px;resize:vertical" placeholder="Explica qué pasó, desde cuándo, qué tan grave es..."></textarea></div>`;
b+=`<div class="ff"><label class="ffl">¿Dónde exactamente?</label><input class="ffi" id="cr_u" placeholder="Ej: baño principal, cocina..."></div>`;
// Photo guide (appears after selecting category)
b+=`<div id="cr_guide" style="display:none"></div>`;
// Photo upload
b+=`<div class="ff"><label class="ffl">📷 Fotos y videos</label><div id="cr_fotos"></div></div>`;
b+=`<button class="bt bp" style="width:100%;padding:12px;font-size:14px" onclick="crSave('${iId}','${pId}')">📩 Enviar reporte</button>`;
$('mbd').innerHTML=b;$('mdl').style.display='flex';document.body.style.overflow='hidden';
_pendFotos=[];initFotoUp('cr_fotos')}

function crCC2(){const catId=$('cr_c').value;$('cr_p').innerHTML='<option value="">Seleccionar...</option>'+PROBS.filter(p=>p.categoria_id===catId).map(p=>`<option value="${p.id}">${p.nombre}</option>`).join('');
// Show guide
const guide=FOTO_GUIDE[catId]||FOTO_GUIDE.otro;const gEl=$('cr_guide');
gEl.innerHTML=`<div class="foto-guide"><div class="foto-guide-t">📷 Guía: qué fotografiar</div>${guide.items.map((item,i)=>`<div class="foto-guide-item"><span class="foto-guide-n">${i+1}</span><span>${item}</span></div>`).join('')}<div class="foto-guide-tip">💡 ${guide.tip}</div></div>`;gEl.style.display='block'}

function crProbChanged(){const prob=PROBS.find(p=>p.id===$('cr_p').value);if(prob&&prob.alerta_seguridad){$('cr_alert').innerHTML=`<div style="padding:10px;background:var(--redbg);border:2px solid var(--rb);border-radius:8px;margin-bottom:10px;font-size:11px;color:var(--red);font-weight:700">🚨 ${prob.alerta_seguridad}</div>`;$('cr_alert').style.display='block'}else $('cr_alert').style.display='none'}

function initFotoUp(containerId){const el=$(containerId);if(!el)return;el.innerHTML=`<div class="foto-up" onclick="document.getElementById('fu_inp').click()"><div class="foto-up-ico">📷</div><div class="foto-up-txt">Toca para agregar fotos o videos</div><div class="foto-up-sub">JPG, PNG, MP4 · Máx 10MB</div></div><input type="file" id="fu_inp" multiple accept="image/*,video/*" style="display:none" onchange="procFiles(this.files)"><div class="foto-prog" id="fu_prog" style="display:none"><span style="width:0%"></span></div><div class="foto-prev" id="fu_prev"></div>`}

async function procFiles(files){const prog=$('fu_prog'),prev=$('fu_prev');prog.style.display='block';const gps=await getGPS();
for(let i=0;i<files.length;i++){prog.querySelector('span').style.width=Math.round(i/files.length*100)+'%';try{const hash=await hashFile(files[i]);const res=await uploadCloud(files[i]);_pendFotos.push({...res,hash,gps_lat:gps.lat,gps_lng:gps.lng,tipo:'reporte'});const it=document.createElement('div');it.className='foto-pi';it.innerHTML=`<img src="${res.thumb}"><button class="foto-x" onclick="this.parentElement.remove();_pendFotos=_pendFotos.filter(f=>f.url!=='${res.url}')">✕</button>`;prev.appendChild(it)}catch(e){toast('Error: '+files[i].name,'terr')}}
prog.querySelector('span').style.width='100%';setTimeout(()=>{prog.style.display='none';prog.querySelector('span').style.width='0%'},1000);if(_pendFotos.length)toast('📷 '+_pendFotos.length+' archivo(s) subidos')}

async function crSave(iId,pId){const cId=$('cr_c').value,prId=$('cr_p').value,d=$('cr_d').value.trim();if(!cId||!d){toast('Completa los campos','twarn');return}const prob=PROBS.find(p=>p.id===prId);
const{data:newC,error}=await SB.from('pv_casos').insert({propiedad_id:pId,inquilino_id:iId,categoria_id:cId,problema_id:prId||null,descripcion:d,urgencia:prob?prob.urgencia_auto:'programable',ubicacion_especifica:$('cr_u').value||null,reportado_por:U.id}).select().single();
if(!error&&newC){
  // Save photos
  for(const f of _pendFotos){await SB.from('pv_evidencias').insert({caso_id:newC.id,tipo:'reporte',url:f.url,url_thumb:f.thumb,hash_sha256:f.hash,gps_lat:f.gps_lat,gps_lng:f.gps_lng,subido_por:'inquilino'})}
  _pendFotos=[];toast('📩 Reporte enviado');cm();await load();
  // Popup to client
  megaAlert('¡Solicitud recibida!','Tu ticket es '+tk(newC.numero_caso)+'. Ya nos ponemos a trabajar para solucionarlo.','info','Entendido');
  // Alert to admin/postventa (simulated - in real app this would be via realtime subscription)
  await SB.from('pv_alertas').insert({tipo:'caso_nuevo',nivel:'rojo',titulo:'🚨 Nueva solicitud: '+(prob?prob.nombre:'Problema reportado'),mensaje:'Inquilino '+U.nombre+' reportó en propiedad. Urgencia: '+(prob?prob.urgencia_auto:'programable'),caso_id:newC.id,de_usuario_id:U.id,para_rol:'postventa'})
}else toast(error?.message||'Error','terr')}

/* MODAL */
function cm(){$('mdl').style.display='none';document.body.style.overflow=''}
document.addEventListener('keydown',e=>{if(e.key==='Escape')cm()});

/* INIT */
window.addEventListener('DOMContentLoaded',()=>{const c=sessionStorage.getItem('pv_u');if(c){try{U=JSON.parse(c);initApp()}catch(e){sessionStorage.removeItem('pv_u')}}});
</script>
