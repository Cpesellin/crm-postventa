<script>
const SU='https://keasjfgcjkskvdcudoml.supabase.co',SK='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtlYXNqZmdjamtza3ZkY3Vkb21sIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2MjIwNDQsImV4cCI6MjA4OTE5ODA0NH0.BfZy552V_WaYITcqWazQaIUHEBAtXA5tJiN_GPWRegw',CN='dfelsbmbo',CP='fichas_unsigned';
const SB=window.supabase.createClient(SU,SK);
let U=null,CASOS=[],PROPS=[],INQS=[],PROFS=[],OWNERS=[],CATS=[],PROBS=[],ALS=[];
const EST=[{id:'reportado',l:'Reportado',c:'c-rep',e:'📩'},{id:'validado',l:'Validado',c:'c-val',e:'✅'},{id:'asignado',l:'Asignado',c:'c-asi',e:'👤'},{id:'en_camino',l:'En camino',c:'c-cam',e:'🚗'},{id:'en_ejecucion',l:'En ejecución',c:'c-eje',e:'🔧'},{id:'completado',l:'Completado',c:'c-com',e:'✓'},{id:'cerrado',l:'Cerrado',c:'c-cer',e:'🏁'}];
const EX={reportado:{i:'📩',t:'Reporte recibido',d:'Tu reporte fue recibido. Nuestro equipo está revisando tu solicitud.'},validado:{i:'✅',t:'Caso validado',d:'Tu caso fue revisado y validado. Buscamos al profesional indicado.'},asignado:{i:'👤',t:'Profesional asignado',d:'Ya tienes profesional. Pronto se pondrá en camino.'},en_camino:{i:'🚗',t:'Profesional en camino',d:'El profesional va hacia tu inmueble. Asegúrate de estar disponible.'},en_ejecucion:{i:'🔧',t:'Reparación en curso',d:'El profesional está trabajando en la reparación.'},completado:{i:'✅',t:'Reparación completada',d:'La reparación fue completada. Por favor califica el servicio.'},cerrado:{i:'🏁',t:'Caso cerrado',d:'Caso cerrado. Tienes garantía activa.'}};
const FOTO_GUIDE={agua_plomeria:{items:['Zona donde sale o gotea el agua','Daño visible en pared, techo o piso','Elementos cercanos afectados','Registro de agua más cercano'],tip:'Buena iluminación. Si hay goteo activo, graba un video corto de 10 segundos.'},electricidad:{items:['Toma o interruptor afectado','Tablero de breakers/tacos','Zona sin energía'],tip:'NO toques cables expuestos. Usa flash del celular si la zona está oscura.'},gas:{items:['Zona donde se sospecha la fuga','Estado de mangueras y conexiones','Registro de gas'],tip:'NO enciendas luces ni interruptores cerca de la fuga. Toma la foto desde distancia segura.'},cerrajeria:{items:['Cerradura o chapa dañada','Puerta completa (para ver alineación)','Marca y modelo si es visible'],tip:'Asegúrate que se vea bien el tipo de cerradura.'},estructura:{items:['Vista general de la grieta o daño','Acercamiento del daño (pon una moneda al lado para referencia de tamaño)','Zona circundante para contexto'],tip:'Si es humedad, toma foto con y sin flash para que se note la mancha.'},carpinteria:{items:['Puerta o ventana completa','Detalle del daño (bisagra, vidrio, marco)','Mecanismo de apertura/cierre'],tip:'Muestra si la puerta/ventana cierra o no en un video corto.'},equipos_inventario:{items:['Equipo completo (marca y modelo visible)','Detalle del daño o falla','Panel de control o display si tiene'],tip:'Si el equipo hace ruido extraño, graba un video con audio.'},otro:{items:['Vista general del problema','Detalle del daño'],tip:'Entre más fotos, más rápido podemos diagnosticar.'}};
let _pendFotos=[],_reminderInterval=null;

/* HELPERS */
function toast(m,t='tok'){const c=document.getElementById('toasts'),e=document.createElement('div');e.className='toast '+t;e.textContent=m;c.appendChild(e);setTimeout(()=>e.remove(),3200)}
let cfR=null;function cfShow(i,t,m){return new Promise(r=>{$('cfi').textContent=i;$('cft').textContent=t;$('cfm').textContent=m;$('cfdlg').style.display='flex';cfR=r;$('cfok').onclick=()=>{$('cfdlg').style.display='none';r(true)}})}function cfX(){$('cfdlg').style.display='none';if(cfR)cfR(false)}
function $(id){return document.getElementById(id)}
function fm(n){return n>0?'$'+Math.round(n).toLocaleString('es-CO'):''}
function tk(n){return'#TK-'+String(n).padStart(4,'0')}
function uB(u){return`<span class="urg ${u==='emergencia'?'emer':u==='urgente'?'urge':'prog'}">${u==='emergencia'?'🔴 Emergencia':u==='urgente'?'🟡 Urgente':'🔵 Programable'}</span>`}
function sB(c){if(!c.sla_vence_at)return'';const r=Math.round((new Date(c.sla_vence_at)-Date.now())/36e5*10)/10;return r<0?`<span class="sla danger">⏱ Vencido</span>`:r<2?`<span class="sla warn">⏱ ${r}h</span>`:`<span class="sla ok">⏱ ${r}h</span>`}
async function hashP(p){const d=new TextEncoder().encode(p+'HOUSE_CRM_SALT_2026'),b=await crypto.subtle.digest('SHA-256',d);return Array.from(new Uint8Array(b)).map(x=>x.toString(16).padStart(2,'0')).join('')}
async function hashFile(file){const buf=await file.arrayBuffer(),h=await crypto.subtle.digest('SHA-256',buf);return Array.from(new Uint8Array(h)).map(x=>x.toString(16).padStart(2,'0')).join('')}
function megaAlert(title,msg,type='info',btn='Entendido'){if(navigator.vibrate)navigator.vibrate([300,100,300,100,300,100,600,200,600]);try{const ac=new(window.AudioContext||window.webkitAudioContext)(),o=ac.createOscillator(),g=ac.createGain();o.connect(g);g.connect(ac.destination);o.frequency.value=type==='emer'?880:660;g.gain.value=0.3;o.start();setTimeout(()=>{o.frequency.value=type==='emer'?1100:880},200);setTimeout(()=>o.stop(),800)}catch(e){}const el=document.createElement('div');el.className='mega '+type;el.innerHTML=`<div class="mega-box"><div class="mega-ico">${type==='emer'?'🚨':type==='urge'?'⚠️':'📩'}</div><div class="mega-tit">${title}</div><div class="mega-msg">${msg}</div><button class="mega-btn ${type}" onclick="this.closest('.mega').remove()">${btn}</button></div>`;$('megas').appendChild(el)}

/* CLOUDINARY */
async function uploadCloud(file){const fd=new FormData();fd.append('file',file);fd.append('upload_preset',CP);fd.append('folder','postventa');const res=await fetch(`https://api.cloudinary.com/v1_1/${CN}/auto/upload`,{method:'POST',body:fd});const data=await res.json();if(data.secure_url)return{url:data.secure_url,thumb:data.secure_url.replace('/upload/','/upload/w_400,c_fill,f_auto/')};throw new Error(data.error?.message||'Upload failed')}
async function getGPS(){return new Promise(r=>{if(!navigator.geolocation){r({lat:null,lng:null});return}navigator.geolocation.getCurrentPosition(p=>r({lat:p.coords.latitude,lng:p.coords.longitude}),()=>r({lat:null,lng:null}),{timeout:5000})})}

/* AUTH */
async function login(){const usr=($('lin_usr').value||'').trim().toLowerCase(),pwd=($('lin_pwd').value||'').trim();if(!usr||!pwd){$('lerr').textContent='Ingresa usuario y contraseña';$('lerr').style.display='block';return}$('lin_btn').disabled=true;$('lin_btn').textContent='Verificando...';$('lerr').style.display='none';try{const h=await hashP(pwd);const{data:user}=await SB.from('pv_usuarios').select('*').eq('usuario',usr).eq('activo',true).single();if(!user||user.password_hash!==h){$('lerr').textContent='Datos incorrectos';$('lerr').style.display='block'}else{U={id:user.id,nombre:user.nombre,rol:user.rol,usuario:user.usuario,telefono:user.telefono,email:user.email};sessionStorage.setItem('pv_u',JSON.stringify(U));initApp()}}catch(e){$('lerr').textContent='Error de conexión';$('lerr').style.display='block'}$('lin_btn').disabled=false;$('lin_btn').textContent='Ingresar'}
function logout(){sessionStorage.removeItem('pv_u');location.reload()}
function initApp(){$('lov').style.display='none';$('mhdr').style.display='block';$('uname').textContent=U.nombre;$('muname').textContent=U.nombre;$('murole').textContent=U.rol.toUpperCase();if(localStorage.getItem('pv_th')==='d'){document.body.classList.add('dark');$('tbtn').textContent='🌙'}bMenu();bSec();load();startReminders()}
function tTh(){const d=document.body.classList.toggle('dark');localStorage.setItem('pv_th',d?'d':'l');$('tbtn').textContent=d?'🌙':'☀️'}
function bMenu(){const R=U.rol;let h='';if(R==='administrador')h=mi('dash','📊','Dashboard')+mi('casos','🎫','Casos')+mi('propiedades','🏠','Propiedades')+mi('inquilinos','👤','Inquilinos')+mi('profesionales','🔧','Profesionales')+mi('propietarios','🏦','Propietarios')+'<div class="mdv"></div>'+mi('alertas','🔔','Alertas')+mi('usuarios','👥','Usuarios');else if(R==='postventa')h=mi('dash','📊','Dashboard')+mi('casos','🎫','Casos')+mi('profesionales','🔧','Civiles')+'<div class="mdv"></div>'+mi('alertas','🔔','Alertas');else if(R==='civil')h=mi('mis_trabajos','🔧','Mis trabajos')+mi('mi_hist','📋','Historial');else h=mi('mi_inm','🏠','Mi inmueble')+mi('mis_rep','📋','Mis reportes');$('mnu').innerHTML=h}
function mi(s,i,l){return`<button class="mi" data-s="${s}" onclick="go('${s}')"><span class="mic">${i}</span>${l}</button>`}
function bSec(){const a=$('app');let h='';const R=U.rol;if(R==='administrador'||R==='postventa')h=sc('dash')+sc('casos')+sc('propiedades')+sc('inquilinos')+sc('profesionales')+sc('propietarios')+sc('alertas')+sc('usuarios');else if(R==='civil')h=sc('mis_trabajos')+sc('mi_hist');else h=sc('mi_inm')+sc('mis_rep');a.innerHTML=h}
function sc(id){return`<div class="sec" id="sec-${id}"></div>`}
function go(s){document.querySelectorAll('.sec').forEach(x=>x.classList.remove('act'));const el=$('sec-'+s);if(el)el.classList.add('act');document.querySelectorAll('.mi').forEach(b=>b.classList.remove('act'));const m=document.querySelector('.mi[data-s="'+s+'"]');if(m)m.classList.add('act');cmenu();window.scrollTo(0,0);ren(s)}
function omenu(){$('mov').classList.add('op');$('mpnl').classList.add('op')}
function cmenu(){$('mov').classList.remove('op');$('mpnl').classList.remove('op')}
function ren(s){const fn={dash:rDash,casos:rCasos,propiedades:rProps,inquilinos:rInqs,profesionales:rProfs,propietarios:rOwners,alertas:rAls,usuarios:rUsers,mis_trabajos:rCivil,mi_hist:rCivHist,mi_inm:rClient,mis_rep:rClientRep};if(fn[s])fn[s]()}

async function load(){try{const[c1,c2,c3,c4,c5,c6,c7,c8]=await Promise.all([SB.from('pv_casos').select('*,propiedad:pv_propiedades(id,tipo,direccion,ciudad,barrio,codigo_interno,torre,piso),inquilino:pv_inquilinos(id,nombre,apellido,telefono_principal,email),profesional:pv_profesionales(id,nombre,apellido,telefono_principal,especialidades,rating_promedio,usuario_id),categoria:pv_categorias(id,nombre,icono),problema:pv_problemas(id,nombre,urgencia_auto,sla_horas,alerta_seguridad)').order('created_at',{ascending:false}),SB.from('pv_propiedades').select('*,propietario:pv_propietarios(id,nombre,apellido,telefono_principal)').eq('activo',true).order('created_at',{ascending:false}),SB.from('pv_inquilinos').select('*,propiedad:pv_propiedades(id,tipo,direccion,ciudad,codigo_interno)').eq('activo',true).order('created_at',{ascending:false}),SB.from('pv_profesionales').select('*').eq('activo',true).order('nombre'),SB.from('pv_propietarios').select('*').eq('activo',true).order('nombre'),SB.from('pv_categorias').select('*').eq('activa',true).order('orden'),SB.from('pv_problemas').select('*').eq('activo',true).order('categoria_id,orden'),SB.from('pv_alertas').select('*').order('created_at',{ascending:false}).limit(100)]);CASOS=c1.data||[];PROPS=c2.data||[];INQS=c3.data||[];PROFS=c4.data||[];OWNERS=c5.data||[];CATS=c6.data||[];PROBS=c7.data||[];ALS=c8.data||[];
if(U.rol==='administrador'||U.rol==='postventa')go('dash');else if(U.rol==='civil')go('mis_trabajos');else go('mi_inm')}catch(e){toast('Error: '+e.message,'terr')}}

/* 30-MIN REMINDERS */
function startReminders(){if(_reminderInterval)clearInterval(_reminderInterval);_reminderInterval=setInterval(checkReminders,60000)}
function checkReminders(){if(U.rol!=='usuario')return;const miInq=findMyInq();if(!miInq)return;const active=CASOS.filter(c=>c.inquilino_id===miInq.id&&!['cerrado','rechazado','cancelado','completado'].includes(c.estado));active.forEach(c=>{const mins=Math.round((Date.now()-new Date(c.fecha_estado).getTime())/60000);if(mins>=30&&mins%30<2)megaAlert('Seguimos trabajando','Tu caso '+tk(c.numero_caso)+' está siendo gestionado. Pronto tendrás novedades.','info','Entendido')})}
function findMyInq(){return INQS.find(i=>i.telefono_principal===U.telefono||i.email===U.email)}

/* ═══ ADMIN / POSTVENTA ═══ */
function rDash(){const el=$('sec-dash');if(!el)return;const ab=CASOS.filter(c=>!['cerrado','rechazado','cancelado'].includes(c.estado)),em=ab.filter(c=>c.urgencia==='emergencia').length,sv=ab.filter(c=>c.sla_vence_at&&new Date(c.sla_vence_at)<new Date()).length;let h=`<div style="padding:16px;background:linear-gradient(155deg,#065f46,#059669);border-radius:var(--r);margin-bottom:12px;color:#fff"><div style="font-family:Fraunces,serif;font-size:20px;font-weight:900">Panel Postventa</div><div style="font-size:10px;opacity:.5;margin-top:2px">Gestión de casos · Tiempo real</div></div>`;
h+=`<div class="dg"><div class="dc"><div class="dn2">${ab.length}</div><div class="dl">Abiertos</div></div><div class="dc" style="border-color:var(--red)"><div class="dn2" style="color:var(--red)">${em}</div><div class="dl">Emergencias</div></div><div class="dc" style="border-color:var(--gold)"><div class="dn2" style="color:var(--gold)">${sv}</div><div class="dl">SLA vencido</div></div><div class="dc"><div class="dn2">${PROPS.length}</div><div class="dl">Propiedades</div></div></div>`;
const urg=ab.filter(c=>c.urgencia==='emergencia'&&c.estado==='reportado');if(urg.length)h+=`<div class="card" style="border-left:4px solid var(--red)"><div class="cdh"><div class="chl"><div class="chi" style="background:var(--redbg)">🚨</div><div><div class="cht" style="color:var(--red)">Emergencias sin atender</div></div></div></div><div class="cdb">${urg.map(cI).join('')}</div></div>`;
h+=`<div class="card"><div class="cdh"><div class="chl"><div class="chi">📋</div><div><div class="cht">Casos recientes</div></div></div><button class="bt bsm bp" onclick="go('casos')">Ver todos →</button></div><div class="cdb">${ab.length?ab.slice(0,8).map(cI).join(''):'<div class="emp"><span class="emp-i">✅</span><h3>Sin casos</h3></div>'}</div></div>`;el.innerHTML=h}
function cI(c){return`<div class="cli" onclick="openC('${c.id}')"><div class="cli-ico">${c.categoria?.icono||'📩'}</div><div class="cli-info"><div class="cli-t">${tk(c.numero_caso)} · ${c.problema?.nombre||c.categoria?.nombre||'?'}</div><div class="cli-s">📍 ${c.propiedad?.direccion||'?'} · 👤 ${c.inquilino?.nombre||'?'}</div></div><div class="cli-r">${uB(c.urgencia)}<br>${sB(c)}<br><span style="font-size:8px;color:var(--sub)">${c.profesional?'🔧 '+c.profesional.nombre:'Sin asignar'}</span></div></div>`}

