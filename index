<body>
<div id="lov"><div class="lbox"><div style="font-size:42px;margin-bottom:10px">🔧</div><div class="lbr">Postventa</div><div class="lsb">Sistema Inmobiliario</div><div class="lfrm"><input id="lin_usr" placeholder="Usuario" autocomplete="username"><input id="lin_pwd" type="password" placeholder="Contraseña" autocomplete="current-password" onkeypress="if(event.key==='Enter')login()"><button onclick="login()" id="lin_btn">Ingresar</button></div><div id="lerr"></div></div></div>
<header id="mhdr" style="display:none"><div class="nav"><div style="display:flex;align-items:center;gap:6px"><button class="ib" onclick="omenu()">☰</button><span style="font-size:18px">🔧</span><div class="lm">Postventa</div></div><div class="nr"><button class="ib" onclick="tTh()" id="tbtn">☀️</button><div class="up"><span id="uname">—</span></div></div></div></header>
